    <h3>Key concepts</h3>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-700">
            <th class="py-2 pr-4 text-left">Structure</th>
            <th class="py-2 pr-4 text-left">Price</th>
            <th class="py-2 text-left">Efficiency</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Perfect competition</td><td class="pr-4">P = MC (price taker)</td><td>Efficient, zero economic profit</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Monopoly</td><td class="pr-4">MR = MC, P > MC (price setter)</td><td>Deadweight loss, positive profit</td></tr>
          <tr><td class="py-2 pr-4">Natural monopoly</td><td class="pr-4">Regulated pricing</td><td>One firm cheapest, but needs oversight</td></tr>
        </tbody>
      </table>
