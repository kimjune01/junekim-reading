---
interface Props {
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
  fin?: string;
}
const { prev, next, fin } = Astro.props;
---
<div class="prev-next">
  {prev ? <a href={prev.href}>&larr; {prev.label}</a> : <span></span>}
  <span class="byline">by <a href="https://june.kim">june.kim</a></span>
  {next ? <a href={next.href}>{next.label} &rarr;</a> : fin ? <span class="fin">{fin}</span> : <span></span>}
</div>

<style>
  .prev-next {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #27272a;
    font-size: 0.875rem;
  }
  .byline {
    color: #4b5563;
    font-size: 0.75rem;
  }
  .fin {
    color: #6b7280;
  }
</style>
